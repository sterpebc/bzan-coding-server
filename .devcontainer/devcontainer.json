{
  "name": "CodingServer Dev Container",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "forwardPorts": [8080],
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-docker",
        "googlecloudtools.cloudcode"
      ]
    }
  },
  // Set the GOOGLE_CLOUD_PROJECT environment variable to provide a quota project.
  // The Google Cloud client libraries will use this project for API billing and quotas.
  "containerEnv": {
    "GOOGLE_CLOUD_PROJECT": "bzan-coding-server"
  },
  "mounts": [
    // Mount the gcloud config directory from your host machine to the container.
    // This syncs your logged-in account and settings (project, region, etc.).
    // Note: This works for Linux/macOS. For Windows, the source path is typically
    // ${localEnv:APPDATA}/gcloud
    "source=${localEnv:HOME}/.config/gcloud,target=/root/.config/gcloud,type=bind,consistency=cached"
  ],
  // By mounting the gcloud config, Application Default Credentials (ADC) will be
  // available automatically. The GOOGLE_APPLICATION_CREDENTIALS variable is no longer needed.
  "postCreateCommand": {
    "pip-install": "pip install --no-cache-dir -r requirements.txt"
  }
}
